# Web3Forms access key — used by the waitlist form to forward signups by email.
#
# How to get your key:
#   1. Go to https://web3forms.com
#   2. Enter tomasizuel@gmail.com (the address that will receive all signups)
#   3. Check that inbox for the confirmation email and click the link
#   4. Copy the access key shown on-screen
#   5. Paste it below and rename this file to .env
#
# If this variable is not set, the form shows the success state locally
# and logs a warning to the browser console — safe for development.
VITE_WEB3FORMS_KEY=your_access_key_here
