    "better-auth": "~1.2.12",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.12",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "unpdf": "^0.12.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3"
