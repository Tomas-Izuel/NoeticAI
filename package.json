{
  "name": "noeticai",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:landing": "pnpm --filter @noeticai/landing dev",
    "dev:web": "pnpm --filter @noeticai/web dev",
    "dev:server": "pnpm --filter @noeticai/server dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
    "reset": "pnpm --filter @noeticai/server reset"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
