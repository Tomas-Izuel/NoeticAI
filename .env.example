# --- Postgres / Redis (docker-compose) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noeticai
REDIS_URL=redis://localhost:6379

# ============================================================
# AI BACKEND — pick "bedrock" (production) or "ollama" (local dev)
# ============================================================
# Phase 0+1 work locally with Ollama until AWS credits land.
# Default below is "bedrock" so production behavior is unchanged;
# flip to "ollama" in apps/server/.env for local dev.
NOETICAI_AI_BACKEND=bedrock

# --- Ollama (only used when NOETICAI_AI_BACKEND=ollama) ---
# Install: brew install ollama && ollama serve
# Recommended models (the user's local setup):
#   ollama pull gemma4:e4b   # LLM, multilingual, ~9.6 GB
#   ollama pull bge-m3       # embed, multilingual, 1024-dim, ~1.2 GB
# bge-m3 is dim-compatible with amazon.titan-embed-text-v2:0 (1024 dim, normalize=false) — same schema.
OLLAMA_BASE_URL=http://localhost:11434
NOETICAI_OLLAMA_LLM_MODEL=gemma4:e4b
NOETICAI_OLLAMA_EMBED_MODEL=bge-m3

# --- AWS / Bedrock (only used when NOETICAI_AI_BACKEND=bedrock) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Pin model IDs at impl time (plan.md §4.1) — IDs below are AWS-native Nova
# defaults (credit-eligible). The opus/sonnet/haiku names are tier *roles*,
# not the underlying family. The opus tier is reserved for syllabus
# extraction (Phase 2). Health checks use the haiku tier (Nova Micro); the
# smoke-llm dev route uses the sonnet tier (Nova Lite).
# Replace with the `us.amazon.nova-*-v1:0` cross-region inference profile
# variants in production env / SSM after confirming availability with
# `aws bedrock list-inference-profiles --region us-east-1`.
NOETICAI_BEDROCK_OPUS_ID=amazon.nova-pro-v1:0
NOETICAI_BEDROCK_SONNET_ID=amazon.nova-lite-v1:0
NOETICAI_BEDROCK_HAIKU_ID=amazon.nova-micro-v1:0

# Embeddings — Amazon Titan Text Embeddings v2 on Bedrock (1024 dim,
# normalize=false). Multilingual via Titan v2's built-in 100+ language
# support; notes/sources default to Spanish (plan.md §4.2). bge-m3 (Ollama)
# remains dim-compatible.
NOETICAI_BEDROCK_EMBED_ID=amazon.titan-embed-text-v2:0

# --- Auth (better-auth) ---
# 32+ chars random. Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=replace-me-with-32-or-more-random-characters
BETTER_AUTH_URL=http://localhost:8080
WEB_URL=http://localhost:3000

# --- Connector token encryption ---
# 32 bytes, base64. Generate: openssl rand -base64 32
SECRET_BOX_KEY=

# --- Notion OAuth ---
# Same client_id/secret powers two flows. Register BOTH redirect URIs in your
# Notion integration's "OAuth Domain & URIs" panel:
#   • http://localhost:8080/api/auth/callback/notion   — sign-in (better-auth)
#   • http://localhost:8080/api/oauth/notion/callback  — workspace connection
# Both vars are optional. If absent, sign-in falls back to email/password and
# the workspace-connection endpoints return 503.
#
# Setup steps:
#   1. Go to https://www.notion.so/my-integrations → "+ New integration"
#   2. Type = "Public" (required for OAuth)
#   3. Add BOTH redirect URIs above to the integration
#   4. Copy the OAuth client ID and secret into the vars below
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:8080/api/oauth/notion/callback

# --- Google OAuth (optional, sign-in only — Phase 7+) ---
# Obtain from https://console.cloud.google.com → APIs & Services → Credentials.
# Redirect URI to register: http://localhost:8080/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Dev knobs ---
# 1 = skip the AI ping in /health (saves time/cost during local iteration).
# Despite the legacy name "BEDROCK", this skips whichever backend is active.
NOETICAI_HEALTH_SKIP_BEDROCK=1

PORT=8080
