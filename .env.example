# --- Postgres / Redis (docker-compose) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noeticai
REDIS_URL=redis://localhost:6379

# ============================================================
# AI BACKEND — pick "bedrock" (production) or "ollama" (local dev)
# ============================================================
# Phase 0+1 work locally with Ollama until AWS credits land.
# Default below is "bedrock" so production behavior is unchanged;
# flip to "ollama" in apps/server/.env for local dev.
NOETICAI_AI_BACKEND=bedrock

# --- Ollama (only used when NOETICAI_AI_BACKEND=ollama) ---
# Install: brew install ollama && ollama serve
# Recommended models (the user's local setup):
#   ollama pull gemma4:e4b   # LLM, multilingual, ~9.6 GB
#   ollama pull bge-m3       # embed, multilingual, 1024-dim, ~1.2 GB
# bge-m3 is dim-compatible with cohere.embed-multilingual-v3 — same schema.
OLLAMA_BASE_URL=http://localhost:11434
NOETICAI_OLLAMA_LLM_MODEL=gemma4:e4b
NOETICAI_OLLAMA_EMBED_MODEL=bge-m3

# --- AWS / Bedrock (only used when NOETICAI_AI_BACKEND=bedrock) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Pin model IDs at impl time (plan.md §4.1) — IDs below are placeholders.
# Opus is reserved for syllabus extraction (Phase 2). It is NOT used for
# completions or any other inline path — too expensive. Health checks use
# Haiku; the smoke-llm dev route uses Sonnet.
NOETICAI_BEDROCK_OPUS_ID=us.anthropic.claude-opus-4-20250514-v1:0
NOETICAI_BEDROCK_SONNET_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
NOETICAI_BEDROCK_HAIKU_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Embeddings — Cohere v3 on Bedrock (1024 dim). Multilingual is the default
# because notes/sources are in Spanish (plan.md §4.2). bge-m3 (Ollama) is
# dim-compatible.
NOETICAI_BEDROCK_EMBED_ID=cohere.embed-multilingual-v3

# --- Auth (better-auth) ---
# 32+ chars random. Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=replace-me-with-32-or-more-random-characters
BETTER_AUTH_URL=http://localhost:8080
WEB_URL=http://localhost:3000

# --- Connector token encryption ---
# 32 bytes, base64. Generate: openssl rand -base64 32
SECRET_BOX_KEY=

# --- Dev knobs ---
# 1 = skip the AI ping in /health (saves time/cost during local iteration).
# Despite the legacy name "BEDROCK", this skips whichever backend is active.
NOETICAI_HEALTH_SKIP_BEDROCK=1

PORT=8080
